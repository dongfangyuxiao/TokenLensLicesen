# TokenLens License Server Configuration

# Database path
DB_PATH=license_admin.db

# License keys paths
LICENSE_PRIVATE_KEY_PATH=keys/license_private.pem
LICENSE_PUBLIC_KEY_PATH=keys/license_public.pem

# Server configuration
HOST=0.0.0.0
PORT=8001

# Session settings
SESSION_TTL_MINUTES=720
SESSION_IDLE_MINUTES=120

# Admin token for API registration and license generation
# Generate a secure token: openssl rand -base64 32
ADMIN_TOKEN=your-secure-admin-token-here
